#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "${ROOT_DIR}"

HOOK_DIR="${ROOT_DIR}/.githooks/pre-commit.d"

if [[ ! -d "${HOOK_DIR}" ]]; then
  exit 0
fi

while IFS= read -r -d '' hook; do
  [[ -x "${hook}" ]] || continue
  "${hook}"
done < <(find "${HOOK_DIR}" -maxdepth 1 -type f -print0 | sort -z)
