{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context/wbs/schemas/operator-decision.schema.json",
  "title": "Operator Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "run_id",
    "seq",
    "slice_id",
    "packet_id",
    "reviewed_trace_ids",
    "made_at",
    "operator_actor",
    "decision",
    "review_summary",
    "reason_code",
    "reason_detail",
    "slice_state_before",
    "slice_state_after",
    "packet_disposition_before",
    "packet_disposition_after",
    "updated_current_ledger_ref"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "seq": {
      "type": "integer",
      "minimum": 1
    },
    "slice_id": {
      "type": "string",
      "minLength": 1
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_trace_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "made_at": {
      "type": "string",
      "minLength": 1
    },
    "operator_actor": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "dispatch",
        "accept",
        "rework",
        "block",
        "cancel",
        "remediate",
        "close"
      ]
    },
    "review_summary": {
      "type": "string",
      "minLength": 1
    },
    "reason_code": {
      "type": "string",
      "enum": [
        "goal_met",
        "insufficient_evidence",
        "missing_input",
        "bad_handoff",
        "contract_violation",
        "harness_issue",
        "slice_redesign_needed",
        "corrective_action_needed"
      ]
    },
    "reason_detail": {
      "type": "string",
      "minLength": 1
    },
    "slice_state_before": {
      "type": "string",
      "enum": [
        "planned",
        "ready",
        "active",
        "blocked",
        "integration_review",
        "done",
        "cancelled"
      ]
    },
    "slice_state_after": {
      "type": "string",
      "enum": [
        "planned",
        "ready",
        "active",
        "blocked",
        "integration_review",
        "done",
        "cancelled"
      ]
    },
    "packet_disposition_before": {
      "type": "string",
      "enum": [
        "issued",
        "active",
        "closed",
        "superseded",
        "cancelled"
      ]
    },
    "packet_disposition_after": {
      "type": "string",
      "enum": [
        "issued",
        "active",
        "closed",
        "superseded",
        "cancelled"
      ]
    },
    "next_packet_id": {
      "type": "string",
      "minLength": 1
    },
    "updated_current_ledger_ref": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_ref": {
      "type": "string",
      "minLength": 1
    },
    "feedback_applied": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "action"
        ],
        "properties": {
          "target": {
            "type": "string",
            "enum": [
              "packet",
              "wbs",
              "contracts",
              "harness",
              "orchestration"
            ]
          },
          "action": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "feedback_opened": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "severity",
          "note"
        ],
        "properties": {
          "target": {
            "type": "string",
            "enum": [
              "packet",
              "wbs",
              "contracts",
              "harness",
              "orchestration"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "must_fix",
              "should_fix",
              "nice_to_have"
            ]
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "context_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
