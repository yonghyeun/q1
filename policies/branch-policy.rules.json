{
  "policy_version": "v2.0.0",
  "default_branch": "main",
  "branch_regex": "^task/i[0-9]+-T-[0-9]{4}-[a-z0-9]+(?:-[a-z0-9]+)*$",
  "issue_token_regex": "^i[0-9]+$",
  "task_id_regex": "^T-[0-9]{4}$",
  "reserved_branches": [
    "main"
  ],
  "required_context_for_push": [
    "context/tasks/{task_id}"
  ],
  "required_artifacts_for_pr": [
    "context.md",
    "result.md"
  ]
}
