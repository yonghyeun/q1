{
  "policy_version": "v1.0.0",
  "default_branch": "main",
  "branch_regex": "^task/T-[0-9]{4}-[a-z0-9]+(?:-[a-z0-9]+)*$",
  "task_id_regex": "^T-[0-9]{4}$",
  "reserved_branches": [
    "main"
  ],
  "required_context_for_push": [
    "agent-team/runs/{task_id}"
  ],
  "required_artifacts_for_pr": [
    "task-brief.json",
    "trace.md",
    "run-log.md",
    "run-report.json"
  ]
}
