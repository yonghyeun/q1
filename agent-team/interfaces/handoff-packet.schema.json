{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adlc.local/schemas/handoff-packet.schema.json",
  "title": "HandoffPacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "from_role",
    "to_role",
    "task",
    "acceptance_checks",
    "context_refs"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^T-[0-9]{4}$"
    },
    "from_stage": {
      "type": "string",
      "enum": [
        "explore",
        "design",
        "execute",
        "improve"
      ]
    },
    "to_stage": {
      "type": "string",
      "enum": [
        "explore",
        "design",
        "execute",
        "improve"
      ]
    },
    "from_role": {
      "type": "string",
      "enum": [
        "adlc-leader",
        "planner-pm",
        "builder",
        "reviewer"
      ]
    },
    "to_role": {
      "type": "string",
      "enum": [
        "adlc-leader",
        "planner-pm",
        "builder",
        "reviewer"
      ]
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "acceptance_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "context_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
