{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adlc.local/schemas/task-brief.schema.json",
  "title": "TaskBrief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal",
    "scope_in",
    "scope_out",
    "constraints",
    "deadline",
    "risk_level"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^T-[0-9]{4}$"
    },
    "created_at": {
      "type": "string",
      "description": "ISO-8601 datetime."
    },
    "stage": {
      "type": "string",
      "enum": [
        "explore",
        "design",
        "execute",
        "improve"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "scope_in": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "scope_out": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deadline": {
      "type": "string",
      "description": "ISO-8601 date or datetime."
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
