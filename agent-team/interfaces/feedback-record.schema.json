{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adlc.local/schemas/feedback-record.schema.json",
  "title": "FeedbackRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "failure_root_cause",
    "fix_type",
    "proposed_change",
    "expected_impact"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^T-[0-9]{4}$"
    },
    "source_run": {
      "type": "string",
      "minLength": 1
    },
    "change_target": {
      "type": "string",
      "enum": [
        "prompt",
        "process",
        "codebase",
        "agents_doc",
        "config"
      ]
    },
    "failure_root_cause": {
      "type": "string",
      "minLength": 1
    },
    "fix_type": {
      "type": "string",
      "enum": [
        "prompt",
        "process",
        "codebase"
      ]
    },
    "proposed_change": {
      "type": "string",
      "minLength": 1
    },
    "expected_impact": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "enum": [
        "adlc-leader",
        "planner-pm",
        "builder",
        "reviewer",
        "human"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "p0",
        "p1",
        "p2"
      ]
    }
  }
}
